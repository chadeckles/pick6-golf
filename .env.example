# ─── Required ────────────────────────────────────────────────
# Used to sign/verify the session JWT. Must be long and random.
# Generate with: openssl rand -base64 48
JWT_SECRET="replace-me-with-a-long-random-string"

# ─── Recommended for production ──────────────────────────────
# Canonical origin the app is served from. Used for CSRF origin
# checks on mutating API routes and for building email links.
APP_URL="https://yourdomain.com"

# Where the SQLite file lives. On a host with a persistent disk,
# point this at that volume (e.g. /data/pick6-golf.db).
DATABASE_PATH="./pick6-golf.db"

# ─── Email (optional; required to actually send reset links) ─
# Leave unset in dev — reset links will log to the server console.
# EMAIL_PROVIDER="resend"
# EMAIL_FROM="Pick 6 Golf <noreply@yourdomain.com>"
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
